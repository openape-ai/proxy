{
  "name": "@openape/proxy",
  "type": "module",
  "version": "0.2.1",
  "description": "OpenApe agent HTTP gateway — forward proxy with grant-based access control",
  "author": "Patrick Hofmann",
  "license": "AGPL-3.0-or-later",
  "bin": {
    "openape-proxy": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm pack --dry-run && npm publish --provenance --access public"
  },
  "dependencies": {
    "@openape/core": "^0.3.0",
    "@openape/grants": "^0.2.0",
    "jose": "^5.9.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@changesets/cli": "^2.29.7",
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "eslint": "^9.35.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openape-ai/proxy.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.29.3"
}
